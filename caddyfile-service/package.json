{
  "name": "caddyfile-editor-service",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "ACCESS_TOKEN=1 CADDYFILE_PATH=./Caddyfile bun run index.ts",
    "start": "ACCESS_TOKEN=1 bun run index.ts",
    "build:linux": "bun build --compile --minify --target=bun-linux-x64 index.ts --outfile dist/FlycastCaddyfileService",
    "build:mac": "bun build --compile --minify --target=bun-darwin-arm64 index.ts --outfile dist/FlycastCaddyfileService-mac"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
